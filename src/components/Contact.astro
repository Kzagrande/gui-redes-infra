---
---
<section class="contact" id="contato">
  <div class="container">
    <div class="contact__grid">
      <div class="contact__info reveal">
        <span class="section-label section-label--light">Fale Conosco</span>
        <h2 class="section-title section-title--light contact__title">
          Pronto para<br />começar?
        </h2>
        <p class="section-sub section-sub--light contact__sub">
          Entre em contato e receba um orçamento sem compromisso.
          Respondemos em até 24 horas úteis.
        </p>

        <a
          href="https://wa.me/5511999999999?text=Ol%C3%A1%21%20Vim%20pelo%20site%20e%20gostaria%20de%20solicitar%20um%20or%C3%A7amento."
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-whatsapp btn--lg contact__wa-btn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          (11) 99999-9999
        </a>

        <a href="mailto:contato@gm-energia.com.br" class="contact__email">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          contato@gm-energia.com.br
        </a>
      </div>

      <div class="contact__form-wrap reveal" data-delay="200">
        <form
          id="contact-form"
          class="contact__form"
          action="mailto:contato@gm-energia.com.br"
          method="POST"
          enctype="text/plain"
          novalidate
        >
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="nome">Nome *</label>
              <input
                class="form-input"
                type="text"
                id="nome"
                name="nome"
                placeholder="Seu nome completo"
                required
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="telefone">Telefone *</label>
              <input
                class="form-input"
                type="tel"
                id="telefone"
                name="telefone"
                placeholder="(11) 99999-9999"
                required
                autocomplete="tel"
              />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="email">E-mail</label>
            <input
              class="form-input"
              type="email"
              id="email"
              name="email"
              placeholder="seu@email.com"
              autocomplete="email"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="servico">Serviço de Interesse</label>
            <select class="form-input" id="servico" name="servico">
              <option value="Instalações Elétricas">Instalações Elétricas</option>
              <option value="Projetos & Laudos Elétricos">Projetos & Laudos Elétricos</option>
              <option value="Manutenção Elétrica">Manutenção Elétrica</option>
              <option value="Cabeamento Estruturado">Cabeamento Estruturado</option>
              <option value="Fibra Óptica">Fibra Óptica</option>
              <option value="Redes & TI">Redes & TI</option>
              <option value="Outro / Não sei ainda">Outro / Não sei ainda</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="mensagem">Mensagem</label>
            <textarea
              class="form-input form-textarea"
              id="mensagem"
              name="mensagem"
              placeholder="Descreva brevemente o que você precisa..."
              rows="4"
            ></textarea>
          </div>

          <div class="form-actions">
            <button type="button" id="btn-wa-form" class="btn btn-whatsapp">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Enviar pelo WhatsApp
            </button>
            <button type="submit" class="btn btn-outline btn-outline--light">
              Enviar por E-mail
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
.contact {
  padding: var(--section-pad);
  background: var(--bg-dark);
}

.contact__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3.5rem;
  align-items: start;
}

@media (min-width: 900px) {
  .contact__grid {
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: center;
  }
}

/* Info side */
.contact__title {
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  margin-bottom: 1rem;
}

.contact__sub {
  margin-bottom: 2.25rem;
}

.contact__wa-btn {
  display: flex;
  width: 100%;
  max-width: 320px;
  margin-bottom: 1.25rem;
  font-size: 1rem;
}

.contact__email {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9375rem;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.6);
  transition: color var(--transition);
}

.contact__email:hover {
  color: rgba(255, 255, 255, 0.95);
}

/* Form side */
.contact__form-wrap {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-lg);
  padding: 2.25rem;
}

.contact__form {
  display: flex;
  flex-direction: column;
  gap: 1.125rem;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

@media (max-width: 560px) {
  .form-row { grid-template-columns: 1fr; }
}

.form-actions {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-top: 0.5rem;
}

@media (min-width: 480px) {
  .form-actions {
    flex-direction: row;
  }

  .form-actions .btn {
    flex: 1;
  }
}
</style>

<script>
const btnWa = document.getElementById('btn-wa-form');

btnWa?.addEventListener('click', () => {
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const get = (name: string) =>
    (form.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement)?.value?.trim() ?? '';

  const nome     = get('nome');
  const telefone = get('telefone');
  const email    = get('email');
  const servico  = get('servico');
  const mensagem = get('mensagem');

  if (!nome || !telefone) {
    alert('Por favor, preencha pelo menos nome e telefone antes de enviar.');
    return;
  }

  const lines = [
    `Olá! Vim pelo site e gostaria de um orçamento.`,
    ``,
    `*Nome:* ${nome}`,
    `*Telefone:* ${telefone}`,
    email    ? `*E-mail:* ${email}`    : '',
    servico  ? `*Serviço:* ${servico}` : '',
    mensagem ? `*Mensagem:* ${mensagem}` : '',
  ].filter(Boolean).join('\n');

  window.open(`https://wa.me/5511999999999?text=${encodeURIComponent(lines)}`, '_blank');
});
</script>
