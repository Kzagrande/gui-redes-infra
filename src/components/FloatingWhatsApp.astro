<style>
.floating-wa {
  position: fixed;
  bottom: 1.75rem;
  right: 1.75rem;
  z-index: 200;
  width: 58px;
  height: 58px;
  border-radius: 50%;
  background-color: var(--color-whatsapp);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
  opacity: 0;
  transform: scale(0.7) translateY(10px);
  transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow var(--transition), background var(--transition);
  pointer-events: none;
}

.floating-wa.visible {
  opacity: 1;
  transform: scale(1) translateY(0);
  pointer-events: auto;
}

.floating-wa:hover {
  background-color: #1da851;
  box-shadow: 0 6px 28px rgba(37, 211, 102, 0.55);
  transform: scale(1.08);
}

/* Tooltip */
.floating-wa__tooltip {
  position: absolute;
  right: calc(100% + 12px);
  top: 50%;
  transform: translateY(-50%);
  background: rgba(13, 27, 62, 0.92);
  color: #FFFFFF;
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 600;
  white-space: nowrap;
  padding: 0.4rem 0.875rem;
  border-radius: var(--radius-pill);
  opacity: 0;
  transition: opacity var(--transition);
  pointer-events: none;
}

.floating-wa:hover .floating-wa__tooltip {
  opacity: 1;
}

@media (max-width: 767px) {
  .floating-wa {
    bottom: 1.25rem;
    right: 1.25rem;
    width: 52px;
    height: 52px;
  }

  .floating-wa__tooltip { display: none; }
}
</style>

<script>
const floatingWa = document.getElementById('floating-wa');

function checkScroll() {
  if (!floatingWa) return;
  const threshold = window.innerHeight * 0.6;
  floatingWa.classList.toggle('visible', window.scrollY > threshold);
}

window.addEventListener('scroll', checkScroll, { passive: true });
checkScroll();
</script>
