---
const steps = [
  {
    num: '01',
    title: 'Contato',
    desc: 'Você nos chama pelo WhatsApp ou formulário. Respondemos rapidamente.',
  },
  {
    num: '02',
    title: 'Diagnóstico',
    desc: 'Avaliamos o local e as necessidades para propor a melhor solução.',
  },
  {
    num: '03',
    title: 'Proposta',
    desc: 'Enviamos um orçamento claro, sem letras miúdas ou surpresas.',
  },
  {
    num: '04',
    title: 'Execução',
    desc: 'Executamos o serviço com qualidade, prazo e suporte pós-entrega.',
  },
];
---
<section class="process" id="processo">
  <div class="container">
    <div class="process__header reveal">
      <span class="section-label">Como Trabalhamos</span>
      <h2 class="section-title process__title">
        Simples do início ao fim.
      </h2>
      <p class="section-sub">
        Quatro etapas para transformar a infraestrutura da sua empresa sem complicações.
      </p>
    </div>

    <div class="process__steps">
      {steps.map((step, i) => (
        <div class="step reveal" data-delay={String(i * 120)}>
          <div class="step__connector" aria-hidden="true"></div>
          <span class="step__bgnum" aria-hidden="true">{step.num}</span>
          <div class="step__node">
            <span class="step__num">{step.num}</span>
            <span class="step__node-glow" aria-hidden="true"></span>
          </div>
          <div class="step__body">
            <h3 class="step__title">{step.title}</h3>
            <p class="step__desc">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="process__cta reveal">
      <a
        href="https://wa.me/5511999999999?text=Ol%C3%A1%21%20Quero%20dar%20in%C3%ADcio%20ao%20processo%20e%20solicitar%20um%20diagn%C3%B3stico."
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-whatsapp btn--lg"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Iniciar Agora pelo WhatsApp
      </a>
    </div>
  </div>
</section>

<style>
.process {
  padding: var(--section-pad);
  background:
    linear-gradient(180deg, var(--bg-secondary) 0%, #e7eefb 100%);
  position: relative;
  overflow: hidden;
}

.process::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at 1px 1px, rgba(10, 61, 145, 0.08) 1px, transparent 0);
  background-size: 28px 28px;
  mask-image: linear-gradient(180deg, transparent 0%, #000 30%, #000 70%, transparent 100%);
  -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 30%, #000 70%, transparent 100%);
  pointer-events: none;
  opacity: 0.6;
}

.process > .container { position: relative; }

.process__header {
  margin-bottom: 3.5rem;
}

.process__title {
  font-size: clamp(2rem, 4vw, 3rem);
  margin-bottom: 1rem;
}

/* Steps grid */
.process__steps {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  position: relative;
  margin-bottom: 3.5rem;
}

@media (min-width: 768px) {
  .process__steps {
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
}

.step {
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
  padding: 0 0 2.5rem 0;
}

@media (min-width: 768px) {
  .step {
    padding: 0 1.5rem 0 0;
    align-items: flex-start;
  }

  .step:last-child { padding-right: 0; }
}

/* Connector line between steps */
.step__connector {
  display: none;
  position: absolute;
  top: 28px;
  left: calc(100% - 1.5rem);
  width: 1.5rem;
  height: 1px;
  background: var(--color-border);
}

.step:not(:last-child) .step__connector {
  display: none;
}

@media (min-width: 768px) {
  .step:not(:last-child) .step__connector {
    display: block;
  }
}

/* Mobile vertical connector */
.step::before {
  content: '';
  display: block;
  position: absolute;
  left: 27px;
  top: 56px;
  bottom: 0;
  width: 1px;
  background: var(--color-border);
  height: calc(100% - 56px);
}

@media (min-width: 768px) {
  .step::before { display: none; }
}

.step:last-child::before { display: none; }

/* Background giant number */
.step__bgnum {
  position: absolute;
  top: -28px;
  left: 0;
  font-family: var(--font-heading);
  font-size: 8rem;
  font-weight: 800;
  line-height: 1;
  color: var(--color-primary);
  opacity: 0.05;
  letter-spacing: -0.04em;
  pointer-events: none;
  user-select: none;
  z-index: 0;
}

@media (max-width: 767px) {
  .step__bgnum {
    font-size: 5.5rem;
    top: -10px;
    left: -8px;
  }
}

/* Node */
.step__node {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  border: 2px solid var(--color-border);
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-bottom: 1.125rem;
  transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
  z-index: 1;
  box-shadow: 0 4px 14px rgba(10, 61, 145, 0.06);
}

.step__node-glow {
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 107, 26, 0.4) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.35s ease;
  pointer-events: none;
  z-index: -1;
}

.step:hover .step__node {
  border-color: var(--color-accent);
  background: linear-gradient(135deg, #fff 0%, var(--bg-secondary) 100%);
  transform: scale(1.08);
  box-shadow: 0 8px 24px rgba(255, 107, 26, 0.18);
}

.step:hover .step__node-glow {
  opacity: 1;
}

.step__num {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  font-weight: 800;
  color: var(--color-accent);
  letter-spacing: -0.01em;
  transition: transform var(--transition);
}

.step:hover .step__num {
  transform: scale(1.1);
}

@media (max-width: 767px) {
  .step {
    flex-direction: row;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .step__node {
    margin-bottom: 0;
    flex-shrink: 0;
  }

  .step__body {
    padding-top: 0.75rem;
  }
}

.step__title {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 0.5rem;
  letter-spacing: -0.01em;
}

.step__desc {
  font-size: 0.9rem;
  color: var(--color-muted);
  line-height: 1.65;
}

/* CTA */
.process__cta {
  display: flex;
  justify-content: center;
}
</style>
