    <div class="hero__visual anim-slide-up anim-d-400" aria-hidden="true">
      <div class="fiber-viz">
        <div class="orbit orbit-1"><div class="ring ring-1"></div><span class="orbit-dot d-1"></span></div>
        <div class="orbit orbit-2"><div class="ring ring-2"></div><span class="orbit-dot d-2"></span></div>
        <div class="orbit orbit-3"><div class="ring ring-3"></div><span class="orbit-dot d-3"></span></div>
        <div class="orbit orbit-4"><div class="ring ring-4"></div><span class="orbit-dot d-4"></span></div>
        <div class="ring ring-5"></div>
        <div class="core"></div>
        <div class="core-pulse"></div>
        <div class="core-pulse core-pulse-2"></div>
        <span class="fiber-label fl-1">Fibra Óptica</span>
        <span class="fiber-label fl-2">Cabeamento</span>
        <span class="fiber-label fl-3">Elétrica</span>
