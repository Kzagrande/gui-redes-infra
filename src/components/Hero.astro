  <a href="#servicos" class="scroll-hint" aria-label="Ver serviços">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </a>
</section>

<style>
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background:
    radial-gradient(ellipse 70% 60% at 0% 110%, rgba(10, 61, 145, 0.07) 0%, transparent 65%),
    radial-gradient(ellipse 50% 40% at 100% 0%, rgba(255, 107, 26, 0.05) 0%, transparent 60%),
    var(--bg-primary);
  padding: 7rem 0 4rem;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at 1px 1px, rgba(10, 61, 145, 0.13) 1px, transparent 0);
  background-size: 32px 32px;
  mask-image: radial-gradient(ellipse 60% 70% at 50% 50%, transparent 30%, #000 100%);
  -webkit-mask-image: radial-gradient(ellipse 60% 70% at 50% 50%, transparent 30%, #000 100%);
  opacity: 0.55;
  pointer-events: none;
}

.hero > * { position: relative; }

.hero__inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3.5rem;
  align-items: center;
}

@media (min-width: 900px) {
  .hero__inner {
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    padding: 0;
  }
}

/* Content */
.hero__headline {
  font-size: clamp(2.8rem, 6.5vw, 5.2rem);
  font-family: var(--font-heading);
  font-weight: 800;
  line-height: 1.03;
  letter-spacing: -0.02em;
  color: var(--color-text);
  margin-bottom: 1.375rem;
}

.hero__headline-accent {
  color: var(--color-accent);
}

.hero__sub {
  font-size: 1.0625rem;
  color: var(--color-muted);
  line-height: 1.75;
  max-width: 46ch;
  margin-bottom: 2.25rem;
}

.hero__sub strong {
  color: var(--color-primary);
  font-weight: 700;
}

.hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 0.875rem;
  margin-bottom: 2rem;
}

/* Badges */
.hero__badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.625rem;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-muted);
  background: var(--bg-secondary);
  border: 1px solid var(--color-border);
  padding: 0.375rem 0.875rem;
  border-radius: var(--radius-pill);
}

.badge svg {
  color: var(--color-accent);
  flex-shrink: 0;
}

/* Fiber visualization */
.hero__visual {
  display: flex;
  justify-content: center;
  align-items: center;
}

.fiber-viz {
  position: relative;
  width: 340px;
  height: 340px;
  flex-shrink: 0;
}

/* Orbit containers — these rotate, taking the dot with them */
.orbit {
  position: absolute;
  top: 50%;
  left: 50%;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  animation: spin-cw linear infinite;
}

.orbit-1 { width: 340px; height: 340px; animation-duration: 38s; animation-direction: reverse; }
.orbit-2 { width: 270px; height: 270px; animation-duration: 26s; }
.orbit-3 { width: 205px; height: 205px; animation-duration: 18s; animation-direction: reverse; }
.orbit-4 { width: 145px; height: 145px; animation-duration: 12s; }

@keyframes spin-cw {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to   { transform: translate(-50%, -50%) rotate(360deg); }
}

.ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border-style: solid;
}

.orbit-1 .ring { border-width: 1px; border-color: var(--color-border); }
.orbit-2 .ring { border-width: 1px; border-color: rgba(10,61,145,0.14); }
.orbit-3 .ring { border-width: 1.5px; border-color: rgba(10,61,145,0.2); border-style: dashed; }
.orbit-4 .ring { border-width: 2px; border-color: rgba(10,61,145,0.28); }
.ring-5 {
  position: absolute;
  width: 90px;
  height: 90px;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 2px solid rgba(10,61,145,0.38);
}

/* Orbiting dot — sits at top of each orbit, rotates with parent */
.orbit-dot {
  position: absolute;
  top: -7px;
  left: 50%;
  transform: translateX(-50%);
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--color-accent);
  box-shadow: 0 0 0 4px rgba(255, 107, 26, 0.16),
              0 0 16px rgba(255, 107, 26, 0.5);
}

.d-1 { background: var(--color-primary); box-shadow: 0 0 0 4px rgba(10,61,145,0.12), 0 0 16px rgba(10,61,145,0.45); }
.d-3 { background: var(--color-primary); box-shadow: 0 0 0 4px rgba(10,61,145,0.12), 0 0 14px rgba(10,61,145,0.4); width: 11px; height: 11px; top: -5.5px; }
.d-2 { width: 11px; height: 11px; top: -5.5px; }
.d-4 { width: 9px; height: 9px; top: -4.5px; }

.core {
  position: absolute;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: pulse 2.8s ease-in-out infinite;
  z-index: 2;
  box-shadow: 0 0 0 6px rgba(10, 61, 145, 0.1),
              0 0 30px rgba(10, 61, 145, 0.35);
}

.core::after {
  content: '';
  position: absolute;
  inset: 9px;
  border-radius: 50%;
  background: var(--color-accent);
  box-shadow: 0 0 12px rgba(255, 107, 26, 0.7);
}

.core-pulse {
  position: absolute;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 2px solid var(--color-accent);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: ripple 2.8s ease-out infinite;
  z-index: 1;
}

.core-pulse-2 {
  animation-delay: 1.4s;
  border-color: var(--color-primary);
}

/* Labels around the viz */
.fiber-label {
  position: absolute;
  font-family: var(--font-body);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-muted);
  white-space: nowrap;
}

.fl-1 { top: 6px; left: 50%; transform: translateX(-50%); }
.fl-2 { top: 50%; right: -4px; transform: translateY(-50%); }
.fl-3 { bottom: 6px; left: 50%; transform: translateX(-50%); }
.fl-4 { top: 50%; left: -4px; transform: translateY(-50%); }

/* Scroll hint */
.scroll-hint {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1.5px solid var(--color-border);
  color: var(--color-muted);
  animation: bounce 2s ease-in-out infinite;
  transition: color var(--transition), border-color var(--transition);
}

.scroll-hint:hover {
  color: var(--color-primary);
  border-color: var(--color-primary);
}

@media (max-width: 899px) {
  .hero__visual { display: none; }
  .fiber-label { display: none; }
}
</style>
